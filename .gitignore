# Claude Code 로컬(머신별) 설정 — 커밋 제외
.claude/settings.local.json

# ROS2 / colcon 빌드 산출물
ros2_ws/build/
ros2_ws/install/
ros2_ws/log/

# 생성물(시각화·결과·맵) — git 제외. 모두 스크립트로 재생성 가능.
# (주의: gitignore 는 인라인 주석 불가 — 주석은 반드시 별도 줄)
# 맵 이미지(패키지 내, launch가 참조 — 로컬 재생성)
*.pgm
# 시각화·결과 전용 출력 폴더 (README 만 추적)
ros2_ws/outputs/*
!ros2_ws/outputs/README.md

# 기타
*.pyc
__pycache__/
.DS_Store
